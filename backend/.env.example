R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=course-companion-content
CACHE_TTL_SECONDS=300
SIGNED_URL_EXPIRY_SECONDS=3600

# Neon PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:pass@host.neon.tech/dbname?sslmode=require

# Stytch authentication
STYTCH_PROJECT_DOMAIN=https://your-project.customers.stytch.com
STYTCH_PROJECT_ID=project-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
STYTCH_SECRET=secret-test-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Stripe one-time payments
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_TEAM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SUCCESS_URL=http://localhost:3000/account?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/account?billing=canceled
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/account
