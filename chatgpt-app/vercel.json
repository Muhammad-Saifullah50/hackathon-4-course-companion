{
  "builds": [
    {
      "src": "server/app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "widgets/dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/mcp/(.*)",
      "dest": "server/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "server/app.py"
    }
  ]
}
