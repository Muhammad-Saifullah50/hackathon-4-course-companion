{
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/mcp/(.*)",
      "dest": "src/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "src/main.py"
    }
  ],
  "env": {
    "BACKEND_URL": "@backend_url",
    "STYTCH_PROJECT_DOMAIN": "@stytch_project_domain",
    "STYTCH_PROJECT_ID": "@stytch_project_id",
    "UPGRADE_URL": "@upgrade_url"
  }
}
